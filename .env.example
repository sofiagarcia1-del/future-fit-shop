# Supabase (Auth + PostgreSQL)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Clave pública (recomendada) — Project Settings → API → Publishable key
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Alternativa legacy (anon JWT); no necesaria si usas publishable key
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Tras crear el proyecto Supabase, ejecuta las migraciones en supabase/migrations/
# (SQL Editor o: supabase db push)

# App URL (opcional en dev; el login usa window.location.origin en el navegador)
# En Cloudflare: configura Redirect URLs en Supabase (ver README), no hace falta cambiar esto para OAuth.
# VITE_APP_URL=http://localhost:8081

# FASHN AI (solo servidor — NO usar prefijo VITE_)
# Obtén tu clave en https://app.fashn.ai/api
FASHN_API_KEY=your-fashn-api-key
FASHN_BASE_URL=https://api.fashn.ai/v1

# Migración supabase/migrations/20250520110000_user_photos_storage.sql
# crea el bucket público "user-photos" para fotos de perfil (Try-On).
