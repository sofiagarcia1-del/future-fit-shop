# Supabase (Auth + PostgreSQL)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Tras crear el proyecto Supabase, ejecuta las migraciones en supabase/migrations/
# (SQL Editor o: supabase db push)

# App URL for OAuth redirects (no trailing slash)
# Dev: use your Vite dev server origin, e.g. http://localhost:8081
VITE_APP_URL=http://localhost:8081
